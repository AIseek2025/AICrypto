# AICrypto Environment Configuration
# Copy this file to .env and fill in values

# Environment: dev | backtest | paper | prod
AICRYPTO_ENV=dev

# Database
DATABASE_URL=postgres://aicrypto:aicrypto@localhost:5432/aicrypto
DB_MAX_CONNECTIONS=10

# Redis
REDIS_URL=redis://localhost:6379

# NATS
NATS_URL=nats://localhost:4222

# Binance API (Testnet by default)
BINANCE_TESTNET=true
BINANCE_REST_URL=https://testnet.binancefuture.com
BINANCE_WS_URL=wss://stream.binancefuture.com/ws
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Logging
RUST_LOG=info
